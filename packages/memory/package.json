  "dependencies": {
    "zod": "^3.24.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
