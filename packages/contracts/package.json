{
  "name": "@agentnova/contracts",
  "version": "0.0.1",
  "description": "AgentNova shared type contracts (permission, tools, sandbox, limits)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xxx/agent-nova",
    "directory": "packages/contracts"
  },
  "homepage": "https://github.com/xxx/agent-nova#readme",
  "keywords": ["agent", "ai", "contracts", "types", "typescript"],
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
