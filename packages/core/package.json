{
  "name": "@agentnova/core",
  "version": "0.0.1",
  "description": "AgentNova core agent engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xxx/agent-nova",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/xxx/agent-nova#readme",
  "keywords": ["agent", "ai", "llm", "core", "typescript"],
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentnova/contracts": "workspace:*",
    "@agentnova/tools": "workspace:*",
    "@agentnova/permission": "workspace:*",
    "@agentnova/memory": "workspace:*",
    "@agentnova/skills": "workspace:*",
    "@agentnova/providers": "workspace:*",
    "ai": "^4.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
