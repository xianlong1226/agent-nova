{
  "name": "agentnova-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "agentnova": "workspace:*",
    "@changesets/cli": "^2.27.0",
    "@changesets/changelog-github": "^0.5.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "tsup": "^8.4.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
